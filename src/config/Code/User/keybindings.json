  {
    "key": "ctrl+shift+g",
    "command": "-kilo-code.generateTerminalCommand"
  },
  {
    "key": "ctrl+alt+i",
    "command": "kilo-code.focusChatInput",
    "when": "true"
  },
  {
    "key": "ctrl+shift+a",
    "command": "-kilo-code.focusChatInput",
    "when": "true"
  },
  {
    "key": "shift+alt+/",
    "command": "kilo-code.ghost.applyAllSuggestions",
    "when": "editorTextFocus && kilocode.ghost.hasSuggestions && !editorTabMovesFocus && !inSnippetMode"
  },
  {
    "key": "alt+]",
    "command": "kilo-code.ghost.goToNextSuggestion",
    "when": "editorTextFocus && kilocode.ghost.hasSuggestions && !editorTabMovesFocus && !inSnippetMode"
  },
  {
    "key": "alt+[",
    "command": "kilo-code.ghost.goToPreviousSuggestion",
    "when": "editorTextFocus && kilocode.ghost.hasSuggestions && !editorTabMovesFocus && !inSnippetMode"
  },
  {
    "key": "shift+escape",
    "command": "kilo-code.ghost.cancelSuggestions",
    "when": "editorTextFocus && kilocode.ghost.hasSuggestions && !editorTabMovesFocus && !inSnippetMode"
  },
  {
    "key": "shift+alt+\\",
    "command": "kilo-code.ghost.generateSuggestions"
  },
  // # dbcode
  // {
  //     "key": "ctrl+shift+alt+d",
  //     "command": "dbcode.connections.view.focus",
  //     "when": "editorHasMultipleSelections && !editorTextFocus || editorHasSelection && !editorTextFocus || !editorHasMultipleSelections && !editorHasSelection"
  // },
